# =============================================================================
# Ad Studio — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# AI Services
# Interfaces are ready — plug in keys when upgrading from mock to real
# -----------------------------------------------------------------------------

# OpenAI (for script generation / GPT-4)
OPENAI_API_KEY=

# ElevenLabs (for AI voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# fal.ai (for image generation / enhancement)
FAL_API_KEY=

# Creatomate (for video rendering)
CREATOMATE_API_KEY=

# -----------------------------------------------------------------------------
# Storage
# Local path is used in development. Switch to Oracle Object Storage in prod.
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage

# Oracle Object Storage (production)
ORACLE_OBJECT_STORAGE_NAMESPACE=
ORACLE_OBJECT_STORAGE_BUCKET=
ORACLE_OBJECT_STORAGE_REGION=
ORACLE_TENANCY_OCID=
ORACLE_USER_OCID=
ORACLE_FINGERPRINT=
ORACLE_PRIVATE_KEY_PATH=

# -----------------------------------------------------------------------------
# Puppeteer
# In production on Oracle Cloud, set PUPPETEER_EXECUTABLE_PATH to the
# path of Chromium installed in the container image.
# -----------------------------------------------------------------------------
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Feature flags (set to "true" to enable)
# -----------------------------------------------------------------------------
# Use real AI APIs instead of mocks
FEATURE_REAL_AI=false
# Enable video export via FFmpeg
FEATURE_FFMPEG_EXPORT=false
